#!/bin/sh
# Força o uso do WSL se chamado a partir de um ambiente Windows (ex: Git Bash)
if [ "$(uname)" != "Linux" ]; then
  wsl sh .husky/pre-commit "$@"
  exit $?
fi

# Se o Laravel Sail estiver ativo, executamos o linting dentro do container
# para garantir consistência total com o ambiente de execução.
if ./vendor/bin/sail ps > /dev/null 2>&1; then
  ./vendor/bin/sail npx lint-staged
else
  # Fallback: Se o Sail estiver desligado, usa o Node/NVM instalado no WSL.
  export NVM_DIR="$HOME/.nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  
  # Shim para PHP (usando php.exe do Herd se necessário no fallback)
  if ! command -v php >/dev/null 2>&1 && command -v php.exe >/dev/null 2>&1; then
    mkdir -p .husky/_/bin
    ln -sf "$(which php.exe)" .husky/_/bin/php
    export PATH="$PWD/.husky/_/bin:$PATH"
  fi

  npx lint-staged
fi
